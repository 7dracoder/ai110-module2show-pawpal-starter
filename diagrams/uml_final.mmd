classDiagram
    class Task {
        +str title
        +str time
        +int duration_minutes
        +str priority
        +str frequency
        +date due_date
        +bool completed
        +mark_complete()
        +next_occurrence()
        +as_row(pet_name)
    }

    class Pet {
        +str name
        +str species
        +list tasks
        +add_task(task)
        +task_count()
    }

    class Owner {
        +str name
        +list pets
        +add_pet(pet)
        +find_pet(pet_name)
        +all_tasks()
    }

    class Scheduler {
        +Owner owner
        +sort_by_time(tasks)
        +sort_by_priority(tasks)
        +filter_tasks(pet_name, completed)
        +detect_conflicts()
        +mark_task_complete(pet_name, task_title)
        +daily_plan()
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : reads
